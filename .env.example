# 복사: cp .env.example .env  (절대 git에 커밋하지 마세요)

# AI 매크로 / 월간 보고서
PERPLEXITY_API_KEY=
# GEMINI_API_KEY=

# DART 자체 팩터 (로컬 ETL / Actions)
DART_API_KEY=

# QuantKing (일일 적재 워크플로용)
# QUANTKING_EMAIL=
# QUANTKING_PASSWORD=
# QUANTKING_TOKEN=

# 선택: Turso 원격 SQLite
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# 베타: 1=로그인 없이 포트 확정·보고서 다운로드 허용 (정식/#3 상점 전 0으로 복구)
# BETA_SKIP_AUTH_GATES=1

# 일일 Actions 요약 메일 (로컬 테스트용 — 레포에는 커밋하지 말 것)
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=gmail_app_password
# NOTIFY_TO=you@gmail.com
